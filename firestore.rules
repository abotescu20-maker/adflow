rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: is user a member of workspace with given role
    function isMember(workspaceId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }
    function hasRole(workspaceId, role) {
      return isMember(workspaceId) &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role == role;
    }
    function hasAnyRole(workspaceId, roles) {
      return isMember(workspaceId) &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role in roles;
    }

    // User profiles — only owner can read/write
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Per-user notifications inbox
      match /notifications/{notifId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        // SECURITY (02.07.2026, H3): bind the notification's actor to the caller so a
        // signed-in user cannot forge WHO a notification appears to come from (in-app
        // phishing). Cross-user delivery is still allowed (sender writes into another
        // inbox with actorId == self); system/fan-out notifications should move to a
        // Cloud Function (P1). Previously `if request.auth != null` let anyone spoof
        // any actor into any inbox.
        allow create: if request.auth != null &&
          request.resource.data.actorId == request.auth.uid;
      }
    }

    // Workspaces — members only
    match /workspaces/{workspaceId} {
      allow read: if isMember(workspaceId);
      // Create: authenticated user can create a workspace where they are the owner
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if hasAnyRole(workspaceId, ['owner', 'admin']);
      allow delete: if hasRole(workspaceId, 'owner');

      // Members subcollection
      match /members/{memberId} {
        allow read: if isMember(workspaceId);
        // Allow user to create themselves as owner during workspace creation
        // (batch write: workspace doc has ownerUid == auth.uid, and member doc is for themselves with role owner)
        allow create: if request.auth != null &&
          request.auth.uid == memberId &&
          request.resource.data.role == 'owner' &&
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUid == request.auth.uid;
        // Admins and owners can add/update/delete other members
        allow update, delete: if hasAnyRole(workspaceId, ['owner', 'admin']) ||
          (request.auth.uid == memberId && request.method == 'delete');
        // A member may set their OWN production context (Black Frame P2: actor
        // type, craft, identity color) via the login picker. Restricted to those
        // four fields with role unchanged, so this can't be used to self-promote.
        allow update: if request.auth != null &&
          request.auth.uid == memberId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['actorType', 'craft', 'color', 'contextSetAt']);
        allow create: if hasAnyRole(workspaceId, ['owner', 'admin']);
      }

      // Campaigns — members can read, editor+ can write
      match /campaigns/{campaignId} {
        allow read: if isMember(workspaceId);
        allow create, update: if hasAnyRole(workspaceId, ['owner', 'admin', 'editor']);
        allow delete: if hasAnyRole(workspaceId, ['owner', 'admin']);

        // Assets under campaigns
        match /assets/{assetId} {
          allow read: if isMember(workspaceId);
          allow write: if hasAnyRole(workspaceId, ['owner', 'admin', 'editor']);

          // Comments on assets
          match /comments/{commentId} {
            allow read: if isMember(workspaceId);
            // SECURITY (02.07.2026, H1): bind authorId to the caller so a member
            // cannot post a comment impersonating another user. update/delete are
            // already keyed on authorId below.
            allow create: if isMember(workspaceId) &&
              request.resource.data.authorId == request.auth.uid;
            allow update, delete: if request.auth != null &&
              resource.data.authorId == request.auth.uid;
          }

          // Version history (append-only from client, edits via editor+)
          match /versions/{versionId} {
            allow read: if isMember(workspaceId);
            allow create: if hasAnyRole(workspaceId, ['owner', 'admin', 'editor']);
            allow update, delete: if hasAnyRole(workspaceId, ['owner', 'admin']);
          }

          // Review rounds under asset
          match /reviewRounds/{roundId} {
            allow read: if isMember(workspaceId);
            allow create, update: if hasAnyRole(workspaceId, ['owner', 'admin', 'editor', 'reviewer']);
            allow delete: if hasAnyRole(workspaceId, ['owner', 'admin']);
          }
        }

        // Deliverables matrix
        match /deliverables/{deliverableId} {
          allow read: if isMember(workspaceId);
          allow write: if hasAnyRole(workspaceId, ['owner', 'admin', 'editor']);
        }
      }

      // Share Links — workspace members can manage
      match /shareLinks/{linkId} {
        allow read: if isMember(workspaceId);
        allow write: if hasAnyRole(workspaceId, ['owner', 'admin', 'editor']);
      }

      // Invitations — admins manage
      match /invitations/{inviteId} {
        allow read: if isMember(workspaceId);
        allow create, update, delete: if hasAnyRole(workspaceId, ['owner', 'admin']);
      }

      // Collections (saved smart filters) — members can read, editor+ can manage
      match /collections/{collectionId} {
        allow read: if isMember(workspaceId);
        allow write: if hasAnyRole(workspaceId, ['owner', 'admin', 'editor']);
      }

      // Activity log — members read; writes are append-only (clients log their own actions,
      // Cloud Functions can backfill). Update/delete forbidden to preserve audit trail.
      match /activity/{entryId} {
        allow read: if isMember(workspaceId);
        allow create: if isMember(workspaceId) &&
          request.resource.data.actorId == request.auth.uid;
        allow update, delete: if false;
      }

      // Chat (Blackframe P3). Threads are visible to the whole team ("vizibil
      // pentru toată lumea"); messages bind the author; the only allowed
      // message update is ticking readBy (the red-until-read mechanism).
      match /threads/{threadId} {
        allow read: if isMember(workspaceId);
        allow create: if isMember(workspaceId) &&
          request.resource.data.createdBy == request.auth.uid;
        allow update: if isMember(workspaceId);
        allow delete: if false;

        match /messages/{msgId} {
          allow read: if isMember(workspaceId);
          allow create: if isMember(workspaceId) &&
            request.resource.data.authorId == request.auth.uid;
          allow update: if isMember(workspaceId) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['readBy']);
          allow delete: if false;
        }
      }

      // Calendar (Blackframe P5) — anyone on the team sees the planning; you
      // only write/remove your own colored spans.
      match /calendarEvents/{eventId} {
        allow read: if isMember(workspaceId);
        allow create: if isMember(workspaceId) &&
          request.resource.data.uid == request.auth.uid;
        allow delete: if isMember(workspaceId) &&
          resource.data.uid == request.auth.uid;
        allow update: if false;
      }

      // Personal notes (Blackframe P5) — strictly private to their owner.
      match /notes/{noteUid} {
        allow read, write: if isMember(workspaceId) &&
          request.auth.uid == noteUid;
      }
    }

    // Public share link access (read-only, token-based, handled via Cloud Functions)
    match /publicShares/{token} {
      allow read: if true;
      allow write: if false;
    }
  }
}
